	author = {Buttle, James M.},
	editor = {Kendall, CAROL and McDONNELL, JEFFREY J.},
	month = jan,
	year = {1998},
	doi = {10.1016/B978-0-444-81546-0.50008-2},
	pages = {1--49},
}

