@incollection{bleam2017,
	title = {Chapter 2 - {Chemical} {Hydrology}},
	isbn = {978-0-12-804178-9},
	url = {https://www.sciencedirect.com/science/article/pii/B9780128041789000021},
	abstract = {Residence time, water-holding capacity, groundwater flow paths and rates, and transport models all contribute to our capacity to predict the impact of soil and aquifer properties on water chemistry and solute movement. A saturated zone water balance that accounts for recharge and discharge provides an estimate of groundwater residence time, a key factor in determining groundwater chemistry. Changes in hydraulic head within the saturated zone determine the hydraulic gradient and groundwater flow paths. Seasonal precipitation and evapotranspiration determine the highly variable vadose zone water balance and soil moisture storage capacity. Darcy’s Law provides a means to estimate pore water velocity that, in turn, influences solute transport rates. The elementary retardation coefficient model and the more detailed plate-theory model are two transport models that predict solute movement along flow paths. Though seemingly very different, both models share a common chemical basis for retarding solute movement.},
	urldate = {2023-09-15},
	booktitle = {Soil and {Environmental} {Chemistry} ({Second} {Edition})},
	publisher = {Academic Press},
	author = {Bleam, William},
