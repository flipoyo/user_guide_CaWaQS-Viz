@article{girard1980,
	title = {An integrated rainfall, surface and underground runoff model.},
	volume = {66},
	issn = {0018-6368},
	doi = {10.1051/lhb/1980030},
	abstract = {The aim of the model discussed here is to simulate simultaneously the surface and the groundwater flow in a hydrological basin. The model is of a deterministic type with a spatial discretization derived from a groundwater model with nested square meshes and from a surface water model with square meshes, which has already been tested on a number of basins. The principle of the model is concentrated on three quite separate functions: The procution function whose role is to separate the rainfall into infiltration and runoff according to the physiographic characteristics of the basin. The surface transport function which leads the runoff water towards the outlets of the hydrographic network by isochromous segments by ensuring mass balance in the meshes. The groundwater transport function which integrates the flow equations in a porous medium of a multilayered field. A study is at present being carried out on the chalk basin of the Lys in northern France. This practical application will make it possible to evaluate the model on an example with a close relationship between aquifer and river. (A)},
	language = {French},
	number = {4-5 , 1980},
