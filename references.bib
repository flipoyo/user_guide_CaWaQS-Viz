	keywords = {Petit bassin versant, Small catchment, débits, décomposition des hydrogrammes, facteur, factor, functional threshold, hydrograph separation, non-linearity, non-linéarité, process, processus, seuil fonctionnel, streamflow, variable active area/period, variable contributing area/period, zone/période active variable, zone/période contributive variable},
	pages = {471--496},
