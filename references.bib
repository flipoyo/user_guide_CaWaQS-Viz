@inproceedings{kurtulus2011,
	address = {Berlin, Heidelberg},
	series = {Studies in {Computational} {Intelligence}},
	title = {Hydraulic {Head} {Interpolation} in an {Aquifer} {Unit} {Using} {ANFIS} and {Ordinary} {Kriging}},
	isbn = {978-3-642-20206-3},
	doi = {10.1007/978-3-642-20206-3_18},
	abstract = {In this study, Ordinary Kriging (ok), and Adaptive Neuro Fuzzy based Inference System (anfis) are evaluated for assessing hydraulic head distribution in an aquifer unit covering 40 km2. Cartesian coordinates of the samples were used as inputs of anfis. Calibrated models are used to interpolate the hydraulic head distribution on a 50 m square - grid. Both simulations have realistic pattern (R2 {\textgreater} 0.97) even if ok performs slightly better than anfis at sampling location. The two methods capture different patterns. The Comparison of the two distributions allow for identifying area of estimate uncertainty, what can be used to improve the sampling network.},
	language = {en},
	booktitle = {Computational {Intelligence}},
	publisher = {Springer},
	author = {Kurtulus, Bedri and Flipo, Nicolas and Goblet, Patrick and Vilain, Guillaume and Tournebize, Julien and Tallec, Gaëlle},
	editor = {Madani, Kurosh and Correia, António Dourado and Rosa, Agostinho and Filipe, Joaquim},
	year = {2011},
